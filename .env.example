# GeM Auto-Tracker - Telegram Bot Configuration
# Copy this file to .env and fill in your details

# Step 1: Open Telegram, search for @BotFather
# Step 2: Send /newbot and follow instructions to create bot
# Step 3: Copy the token given by BotFather below
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Step 4: Start your bot (send it any message)
# Step 5: Open: https://api.telegram.org/bot<TOKEN>/getUpdates
# Step 6: Look for "chat": {"id": XXXXXXXXX} - that number is your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here
